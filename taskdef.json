{
  "family": "myapp-task",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "myapp-container",
      "image": "<IMAGE1_NAME>",
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "essential": true
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::418891623126:role/ecsTaskExecutionRole"
}